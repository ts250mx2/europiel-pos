<MudThemeProvider Theme="_tema" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<Router AppAssembly="@typeof(Main).Assembly">
    <Found Context="routeData">
        <RouteView RouteData="@routeData" DefaultLayout="@typeof(DisenoPrincipal)" />
    </Found>
    <NotFound>
        <MudText Typo="Typo.h5" Class="ma-8">Página no encontrada.</MudText>
    </NotFound>
</Router>

@code {
    // Paleta de marca Europiel Láser Center:
    //   carbón #2C3840 (fondo del logo), turquesas de los círculos
    //   (#A8E4EC → #6FCFDE → #35AABD → #1D8296), blanco y gris claro.
    public const string Carbon = "#2C3840";
    public const string CarbonClaro = "#3A4750";
    public const string Turquesa = "#1D8296";
    public const string TurquesaMedio = "#35AABD";
    public const string TurquesaClaro = "#6FCFDE";
    public const string TurquesaSuave = "#A8E4EC";

    private readonly MudTheme _tema = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = Turquesa,
            PrimaryLighten = TurquesaClaro,
            PrimaryDarken = "#136575",
            Secondary = TurquesaMedio,
            Tertiary = TurquesaSuave,
            AppbarBackground = Carbon,
            AppbarText = "#FFFFFF",
            Background = "#F2F6F7",
            Surface = "#FFFFFF",
            TextPrimary = Carbon,
            TextSecondary = "#5C6B73",
            DrawerBackground = Carbon,
            DrawerText = "#D7DDE0",
            Info = TurquesaMedio,
        },
        LayoutProperties = new LayoutProperties
        {
            DefaultBorderRadius = "10px",
        },
    };
}
