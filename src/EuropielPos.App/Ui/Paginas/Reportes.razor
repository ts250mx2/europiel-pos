@page "/reportes"
@inject EuropielPos.Data.Services.Reportes.IReporteCentralService ReportesServicio
@inject EuropielPos.Domain.Sesion.SesionPos Sesion
@inject NavigationManager Nav
@inject ISnackbar Snackbar

@if (!Sesion.Autenticado)
{
    <MudAlert Severity="Severity.Warning" Class="ma-8">
        Sesión no iniciada. <MudLink Href="/">Ir al login</MudLink>
    </MudAlert>
}
else
{
    <MudContainer MaxWidth="MaxWidth.Large" Class="pa-6">
        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
            <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="@(() => Nav.NavigateTo("/inicio"))" />
            <MudText Typo="Typo.h5"><b>Reportes</b></MudText>
        </MudStack>

        <MudPaper Elevation="2" Class="pa-4 rounded-xl mb-6">
            <MudText Typo="Typo.subtitle2" Class="mb-2">Rango de fechas</MudText>
            <MudStack Row="true" Spacing="3" Wrap="Wrap.Wrap">
                <MudDatePicker @bind-Date="_fechaInicio" Label="Fecha inicio" Variant="Variant.Outlined"
                               Style="max-width:200px;" />
                <MudDatePicker @bind-Date="_fechaFin" Label="Fecha fin" Variant="Variant.Outlined"
                               Style="max-width:200px;" />
            </MudStack>
        </MudPaper>

        <MudGrid>
            <MudItem xs="12" sm="6">
                <MudPaper Elevation="2" Class="pa-6 rounded-xl d-flex flex-column align-center" Style="height:100%;">
                    <MudIcon Icon="@Icons.Material.Filled.Today" Color="Color.Primary" Style="font-size: 3.5rem;" />
                    <MudText Typo="Typo.h6" Class="mt-2"><b>Reporte diario</b></MudText>
                    <MudText Typo="Typo.body2" Class="mud-text-secondary mb-4" Align="Align.Center">
                        Pagos pendientes con cita, cobranza atrasada, citas del día,
                        comisiones y clientes para valoración; por sucursal del bloque.
                    </MudText>
                    <MudSpacer />
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                               StartIcon="@Icons.Material.Filled.Description"
                               Disabled="_generandoDiario" OnClick="GenerarReporteDiario">
                        @(_generandoDiario ? "Generando..." : "Generar")
                    </MudButton>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudPaper Elevation="2" Class="pa-6 rounded-xl d-flex flex-column align-center" Style="height:100%;">
                    <MudIcon Icon="@Icons.Material.Filled.PointOfSale" Color="Color.Secondary" Style="font-size: 3.5rem;" />
                    <MudText Typo="Typo.h6" Class="mt-2"><b>Consulta de caja</b></MudText>
                    <MudText Typo="Typo.body2" Class="mud-text-secondary mb-4" Align="Align.Center">
                        Cobros del periodo con totales a depositar e ingresos
                        por forma de pago.
                    </MudText>
                    <MudSpacer />
                    <MudButton Variant="Variant.Filled" Color="Color.Secondary" FullWidth="true"
                               StartIcon="@Icons.Material.Filled.Description"
                               Disabled="_generandoCaja" OnClick="GenerarConsultaCaja">
                        @(_generandoCaja ? "Generando..." : "Generar")
                    </MudButton>
                </MudPaper>
            </MudItem>
        </MudGrid>

        @if (_generandoDiario || _generandoCaja)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mt-4" />
            <MudText Typo="Typo.body2" Class="mud-text-secondary mt-1" Align="Align.Center">
                Generando reporte, esto puede tardar unos minutos...
            </MudText>
        }
    </MudContainer>
}

@code {
    private DateTime? _fechaInicio = DateTime.Today;
    private DateTime? _fechaFin = DateTime.Today;
    private bool _generandoDiario;
    private bool _generandoCaja;

    private bool FechasValidas()
    {
        // Misma validación del formulario original.
        if (_fechaInicio is null || _fechaFin is null || _fechaInicio > _fechaFin)
        {
            Snackbar.Add("Fecha Inicio o Fin invalida", Severity.Warning);
            return false;
        }

        return true;
    }

    private async Task GenerarReporteDiario()
    {
        if (!FechasValidas())
            return;

        _generandoDiario = true;
        try
        {
            string ruta = await ReportesServicio.GeneraArchivoReporteDiarioAsync(
                _fechaInicio!.Value, _fechaFin!.Value, Sesion.IdUsuario);
            AbrirArchivo(ruta);
            Snackbar.Add("Archivo generado", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add("Error al generar el reporte: " + ex.Message, Severity.Error);
        }
        finally
        {
            _generandoDiario = false;
        }
    }

    private async Task GenerarConsultaCaja()
    {
        if (!FechasValidas())
            return;

        _generandoCaja = true;
        try
        {
            string ruta = await ReportesServicio.GeneraArchivoConsultaCajaAsync(
                _fechaInicio!.Value, _fechaFin!.Value);
            AbrirArchivo(ruta);
            Snackbar.Add("Archivo generado", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add("Error al generar el reporte: " + ex.Message, Severity.Error);
        }
        finally
        {
            _generandoCaja = false;
        }
    }

    /// <summary>Abre el HTML en el navegador; el window.print() del reporte
    /// lanza el diálogo de impresión (sustituye a Crystal en consulta de caja).</summary>
    private static void AbrirArchivo(string ruta)
    {
        System.Diagnostics.Process.Start(new System.Diagnostics.ProcessStartInfo
        {
            FileName = ruta,
            UseShellExecute = true,
        });
    }
}
