@page "/agenda"
@inject EuropielPos.Data.Services.IAgendaService AgendaServicio
@inject EuropielPos.Data.Services.Sincronizacion.ISincronizacionOrquestador Orquestador
@inject EuropielPos.Domain.Sincronizacion.ContextoPos Contexto
@inject EuropielPos.Domain.Sesion.SesionPos Sesion
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IDialogService Dialogos

@if (!Sesion.Autenticado)
{
    <MudAlert Severity="Severity.Warning" Class="ma-8">
        Sesión no iniciada. <MudLink Href="/">Ir al login</MudLink>
    </MudAlert>
}
else
{
    <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-6">

        @* ---------- Barra de la agenda ---------- *@
        <MudPaper Elevation="2" Class="pa-4 rounded-xl mb-4">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Wrap="Wrap.Wrap">
                <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="@(() => Nav.NavigateTo("/inicio"))" />
                <MudText Typo="Typo.h5" Class="mr-4"><b>Agenda</b></MudText>

                <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft" OnClick="@(() => CambiarDia(-1))" />
                <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="@(() => IrAFecha(DateTime.Today))">Hoy</MudButton>
                <MudIconButton Icon="@Icons.Material.Filled.ChevronRight" OnClick="@(() => CambiarDia(1))" />

                <MudDatePicker Date="_fecha" DateChanged="@(f => IrAFecha(f ?? DateTime.Today))"
                               Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width: 180px;" />

                <MudText Typo="Typo.subtitle1" Class="ml-2" Style="text-transform: capitalize;">
                    @_fecha.ToString("dddd d 'de' MMMM")
                </MudText>

                <MudSpacer />

                <MudChip T="string" Color="Color.Primary" Variant="Variant.Text">@_citas.Count citas</MudChip>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.Add" OnClick="@(() => Nav.NavigateTo("/agenda/nueva"))">
                    Nueva cita
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.Sync" Disabled="_sincronizando" OnClick="Sincronizar">
                    @(_sincronizando ? "Sincronizando..." : "Sincronizar")
                </MudButton>
            </MudStack>

            @* Leyenda de colores (reglas del POS original) *@
            <MudStack Row="true" Spacing="2" Class="mt-3" Wrap="Wrap.Wrap">
                <MudChip T="string" Size="Size.Small" Style="@Pastilla("#1D8296")">Programada</MudChip>
                <MudChip T="string" Size="Size.Small" Style="@Pastilla("#4CAF50")">Asistida</MudChip>
                <MudChip T="string" Size="Size.Small" Style="@Pastilla("#8E5BC8")">Morada (cobranza)</MudChip>
                <MudChip T="string" Size="Size.Small" Style="@Pastilla("#78909C")">Bloqueada</MudChip>
                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                         Icon="@Icons.Material.Filled.CloudOff">Pendiente de sincronizar</MudChip>
            </MudStack>
        </MudPaper>

        @* ---------- Vista de día ---------- *@
        @if (_cargando)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }
        else if (_citas.Count == 0)
        {
            <MudPaper Elevation="1" Class="pa-12 rounded-xl d-flex flex-column align-center">
                <MudIcon Icon="@Icons.Material.Filled.EventAvailable" Style="font-size: 4rem; opacity:.3;" />
                <MudText Typo="Typo.h6" Class="mt-3 mud-text-secondary">Sin citas para este día</MudText>
            </MudPaper>
        }
        else
        {
            <MudPaper Elevation="1" Class="rounded-xl" Style="overflow: hidden;">
                @foreach (var hora in _horas)
                {
                    var citasHora = _citas.Where(c => c.FechaInicio?.Hour == hora).ToList();

                    <div style="display: flex; border-bottom: 1px solid #E4EAEC; min-height: 56px;">
                        <div style="width: 80px; flex-shrink: 0; padding: 10px; text-align: right;
                                    color: #5C6B73; font-size: .85rem; border-right: 2px solid #D5DEE1;">
                            @($"{hora:00}:00")
                        </div>
                        <div style="flex: 1; padding: 6px; display: flex; flex-wrap: wrap; gap: 6px;">
                            @foreach (var cita in citasHora)
                            {
                                <div style="@EstiloCita(cita)" @onclick="@(() => AbrirDetalle(cita.IdLocal))">
                                    <div style="display:flex; align-items:center; gap:6px;">
                                        <b>@cita.FechaInicio?.ToString("HH:mm")–@cita.FechaFin?.ToString("HH:mm")</b>
                                        <span>@cita.Paciente</span>
                                        @if (cita.PendienteSincronizar)
                                        {
                                            <MudIcon Icon="@Icons.Material.Filled.CloudOff" Style="font-size:.95rem;"
                                                     Title="Pendiente de sincronizar" />
                                        }
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(cita.ListaServicios))
                                    {
                                        <div style="font-size:.75rem; opacity:.85; margin-top:2px;">@cita.ListaServicios</div>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(cita.TipoCita))
                                    {
                                        <div style="font-size:.7rem; opacity:.7;">@cita.TipoCita</div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }
            </MudPaper>
        }
    </MudContainer>

    @* ---------- Dialog de detalle de cita ---------- *@
    <MudDialog @bind-Visible="_detalleAbierto" Options="_opcionesDialog">
        <TitleContent>
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.EventNote" Color="Color.Primary" />
                <MudText Typo="Typo.h6">Detalle de la cita</MudText>
            </MudStack>
        </TitleContent>
        <DialogContent>
            @if (_detalle is null)
            {
                <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
            }
            else
            {
                <MudStack Spacing="3">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" />
                        <MudText Typo="Typo.subtitle1"><b>@_detalle.Paciente</b></MudText>
                        @if (_detalle.PendienteSincronizar)
                        {
                            <MudChip T="string" Size="Size.Small" Icon="@Icons.Material.Filled.CloudOff"
                                     Color="Color.Warning">Sin sincronizar</MudChip>
                        }
                    </MudStack>

                    <MudGrid Spacing="2">
                        <MudItem xs="6">
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Horario</MudText>
                            <MudText Typo="Typo.body2">
                                @_detalle.FechaInicio?.ToString("dd/MM/yyyy HH:mm") – @_detalle.FechaFin?.ToString("HH:mm")
                            </MudText>
                        </MudItem>
                        <MudItem xs="6">
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Tipo</MudText>
                            <MudText Typo="Typo.body2">@(_detalle.TipoCita ?? "—")</MudText>
                        </MudItem>
                        <MudItem xs="6">
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Teléfonos</MudText>
                            <MudText Typo="Typo.body2">@Junta(_detalle.Telefono1, _detalle.Telefono2)</MudText>
                        </MudItem>
                        <MudItem xs="6">
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Email</MudText>
                            <MudText Typo="Typo.body2">@(string.IsNullOrWhiteSpace(_detalle.Email) ? "—" : _detalle.Email)</MudText>
                        </MudItem>
                        <MudItem xs="6">
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Paquete</MudText>
                            <MudText Typo="Typo.body2">@(_detalle.IdPaquete is > 0 ? $"#{_detalle.IdPaquete}" : "—")</MudText>
                        </MudItem>
                        <MudItem xs="6">
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">Agendada el</MudText>
                            <MudText Typo="Typo.body2">@(_detalle.FechaAlta?.ToString("dd/MM/yyyy HH:mm") ?? "—")</MudText>
                        </MudItem>
                    </MudGrid>

                    <div>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary mb-1">Servicios</MudText>
                        @if (_detalle.Servicios.Count == 0)
                        {
                            <MudText Typo="Typo.body2">—</MudText>
                        }
                        else
                        {
                            <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                                @foreach (var servicio in _detalle.Servicios)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Text">@servicio</MudChip>
                                }
                            </MudStack>
                        }
                    </div>

                    @if (!string.IsNullOrWhiteSpace(_detalle.MsgEstatusInterfaz))
                    {
                        <MudAlert Severity="Severity.Warning" Dense="true">
                            Servidor: @_detalle.MsgEstatusInterfaz
                        </MudAlert>
                    }
                </MudStack>
            }
        </DialogContent>
        <DialogActions>
            @if (_detalle is not null)
            {
                @if (_detalle.PendienteSincronizar)
                {
                    <MudButton Color="Color.Primary" StartIcon="@Icons.Material.Filled.CloudUpload"
                               Disabled="_accionEnCurso" OnClick="EnviarAhora">Enviar ahora</MudButton>
                }
                <MudButton Color="Color.Error" StartIcon="@Icons.Material.Filled.EventBusy"
                           Disabled="_accionEnCurso" OnClick="CancelarCita">Cancelar cita</MudButton>
            }
            <MudSpacer />
            <MudButton OnClick="@(() => _detalleAbierto = false)">Cerrar</MudButton>
        </DialogActions>
    </MudDialog>
}

@code {
    private DateTime _fecha = DateTime.Today;
    private List<EuropielPos.Data.Services.CitaAgenda> _citas = [];
    private bool _cargando;
    private bool _sincronizando;
    private readonly int[] _horas = Enumerable.Range(8, 14).ToArray(); // 8:00 a 21:00

    // Dialog de detalle
    private bool _detalleAbierto;
    private bool _accionEnCurso;
    private EuropielPos.Data.Services.CitaDetalle? _detalle;
    private readonly DialogOptions _opcionesDialog = new() { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true };

    private async Task AbrirDetalle(int idLocal)
    {
        _detalle = null;
        _detalleAbierto = true;

        try
        {
            _detalle = await AgendaServicio.DetalleCitaAsync(idLocal);

            if (_detalle is null)
            {
                _detalleAbierto = false;
                Snackbar.Add("La cita ya no existe; actualizando agenda.", Severity.Info);
                await Cargar();
            }
        }
        catch (Exception ex)
        {
            _detalleAbierto = false;
            Snackbar.Add("Error al cargar el detalle: " + ex.Message, Severity.Error);
        }
    }

    private async Task EnviarAhora()
    {
        if (_detalle is null)
            return;

        _accionEnCurso = true;
        try
        {
            await Orquestador.EnvioCitaOnLineAsync(_detalle.IdLocal);
            Snackbar.Add("Cita enviada al servidor.", Severity.Success);
            await AbrirDetalle(_detalle.IdLocal); // recargar con estado nuevo
            await Cargar();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _accionEnCurso = false;
        }
    }

    private async Task CancelarCita()
    {
        if (_detalle is null)
            return;

        bool? confirmado = await Dialogos.ShowMessageBox(
            "Cancelar cita",
            $"¿Seguro que deseas borrar la cita de {_detalle.Paciente}?",
            yesText: "Sí, cancelar", cancelText: "No");

        if (confirmado != true)
            return;

        _accionEnCurso = true;
        try
        {
            string? error = await AgendaServicio.CancelarCitaAsync(_detalle.IdLocal, Sesion.IdUsuario);

            if (error is null)
            {
                _detalleAbierto = false;
                Snackbar.Add("Cita cancelada.", Severity.Success);
                await Cargar();
            }
            else
            {
                Snackbar.Add(error, Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _accionEnCurso = false;
        }
    }

    private static string Junta(string? a, string? b)
    {
        var partes = new[] { a, b }.Where(x => !string.IsNullOrWhiteSpace(x)).ToList();
        return partes.Count == 0 ? "—" : string.Join(" / ", partes);
    }

    protected override async Task OnInitializedAsync() => await Cargar();

    private async Task Cargar()
    {
        _cargando = true;
        try
        {
            _citas = await AgendaServicio.CitasDelDiaAsync(_fecha, Contexto.IdSucursal);
        }
        catch (Exception ex)
        {
            Snackbar.Add("Error al cargar la agenda: " + ex.Message, Severity.Error);
        }
        finally
        {
            _cargando = false;
        }
    }

    private async Task CambiarDia(int dias) => await IrAFecha(_fecha.AddDays(dias));

    private async Task IrAFecha(DateTime fecha)
    {
        _fecha = fecha.Date;
        await Cargar();
    }

    private async Task Sincronizar()
    {
        _sincronizando = true;
        try
        {
            await Orquestador.ProcesoInterfazCitasAsync();
            await Cargar();
            Snackbar.Add("Agenda sincronizada.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add("Error al sincronizar: " + ex.Message, Severity.Error);
        }
        finally
        {
            _sincronizando = false;
        }
    }

    // Colores según las reglas del original (cita_estatus_color).
    private static string ColorDe(EuropielPos.Data.Services.CitaAgenda c) => c switch
    {
        { Bloqueada: true } => "#78909C",
        { EsMorada: true } => "#8E5BC8",
        { Asistida: true } => "#4CAF50",
        _ => "#1D8296",
    };

    private static string EstiloCita(EuropielPos.Data.Services.CitaAgenda c) =>
        $"background: {ColorDe(c)}; color: white; border-radius: 8px; padding: 6px 12px; " +
        "min-width: 220px; box-shadow: 0 1px 3px rgba(0,0,0,.25); font-size: .85rem; cursor: pointer;";

    private static string Pastilla(string color) =>
        $"background: {color}; color: white;";
}
