@page "/inicio"
@inject EuropielPos.Domain.Sesion.SesionPos Sesion
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.Large" Class="pa-8">
    @if (!Sesion.Autenticado)
    {
        <MudAlert Severity="Severity.Warning" Class="mt-8">
            Sesión no iniciada. <MudLink Href="/">Ir al login</MudLink>
        </MudAlert>
    }
    else
    {
        <MudText Typo="Typo.h4" Class="mb-1">Hola, @Sesion.UsuarioNombre 👋</MudText>
        <MudText Typo="Typo.body1" Class="mud-text-secondary mb-8">
            @Sesion.NombreSucursal · @DateTime.Now.ToString("dddd d 'de' MMMM yyyy")
        </MudText>

        <MudGrid Spacing="4">
            @foreach (var modulo in _modulos)
            {
                <MudItem xs="6" sm="4" md="3">
                    <MudPaper Elevation="3" Class="pa-6 rounded-xl d-flex flex-column align-center mud-ripple"
                              Style="cursor: pointer; transition: transform .15s;"
                              @onclick="@(() => AbrirModulo(modulo))">
                        <MudIcon Icon="@modulo.Icono" Color="@(modulo.Disponible ? Color.Primary : Color.Default)"
                                 Style="font-size: 3rem;" Class="mb-3" />
                        <MudText Typo="Typo.subtitle1" Align="Align.Center"><b>@modulo.Nombre</b></MudText>
                        @if (!modulo.Disponible)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Default" Class="mt-2">Próximamente</MudChip>
                        }
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>
    }
</MudContainer>

@code {
    private record Modulo(string Nombre, string Icono, string? Ruta, bool Disponible);

    private readonly List<Modulo> _modulos =
    [
        new("Caja", Icons.Material.Filled.PointOfSale, null, false),
        new("Agenda", Icons.Material.Filled.CalendarMonth, "/agenda", true),
        new("Ventas", Icons.Material.Filled.ShoppingCart, null, false),
        new("Clientes", Icons.Material.Filled.People, null, false),
        new("Requerimientos", Icons.Material.Filled.Assignment, null, false),
        new("GIOs", Icons.Material.Filled.Badge, null, false),
        new("Reportes", Icons.Material.Filled.Assessment, null, false),
        new("Sincronización", Icons.Material.Filled.Sync, "/sincronizacion", false),
    ];

    private void AbrirModulo(Modulo modulo)
    {
        if (modulo.Disponible && modulo.Ruta is not null)
            Nav.NavigateTo(modulo.Ruta);
        else
            Snackbar.Add($"{modulo.Nombre}: este módulo se portará en la siguiente fase.", Severity.Info);
    }
}
