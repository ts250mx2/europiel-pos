@inherits LayoutComponentBase
@inject EuropielPos.Domain.Sesion.SesionPos Sesion
@inject NavigationManager Nav

@if (Sesion.Autenticado)
{
    <MudLayout>
        <MudAppBar Elevation="2">
            @* Mini logotipo de marca en la barra *@
            <div style="display: flex; gap: 4px; margin-right: 10px;">
                <span style="width:9px; height:9px; border-radius:50%; background:@Main.TurquesaSuave;"></span>
                <span style="width:9px; height:9px; border-radius:50%; background:@Main.TurquesaClaro;"></span>
                <span style="width:9px; height:9px; border-radius:50%; background:@Main.TurquesaMedio;"></span>
                <span style="width:9px; height:9px; border-radius:50%; background:@Main.Turquesa;"></span>
            </div>
            <MudText Typo="Typo.h6" Style="font-weight: 700; letter-spacing: -0.5px;">
                <span style="color:#FFFFFF;">euro</span><span style="color:@Main.TurquesaClaro;">piel</span>
            </MudText>
            <MudText Typo="Typo.caption" Style="letter-spacing: 3px; opacity:.6; margin-left:10px;">POS</MudText>
            <MudSpacer />
            <MudText Typo="Typo.body2" Class="mr-4" Style="opacity:.85;">
                @Sesion.NombreSucursal · @Sesion.UsuarioNombre (@Sesion.TipoUsuario)
            </MudText>
            <MudIconButton Icon="@Icons.Material.Filled.Logout" Color="Color.Inherit"
                           Title="Cerrar sesión" OnClick="CerrarSesion" />
        </MudAppBar>
        <MudMainContent>
            @Body
        </MudMainContent>
    </MudLayout>
}
else
{
    @* Sin sesión (login/configuración) no hay AppBar: la página ocupa todo,
       sin el padding superior que MudMainContent reserva para la barra. *@
    @Body
}

@code {
    private void CerrarSesion()
    {
        Sesion.Cerrar();
        Nav.NavigateTo("/");
    }
}
